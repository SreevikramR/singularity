[Desktop Entry]
Name=Singularity
Comment=Unified quick-settings panel applet for COSMIC
Type=Application
Icon=com.github.sreevikramr.singularity
Exec=singularity %F
Terminal=false
StartupNotify=true
Categories=COSMIC
Keywords=COSMIC
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
MimeType=
